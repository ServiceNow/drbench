# DrBench Environment Configuration
# Copy to .env and fill in your values:
#
#   cp .env.example .env
#
# HOW TO ADD NEW CONFIGURATION KEYS:
# 1. Add the new key in the appropriate section below
# 2. Add a corresponding line in drbench/config.py:
#    KEY_NAME = os.getenv("KEY_NAME", "optional_default_value")
# 3. Use it in your code: from drbench import config; config.KEY_NAME


# ===========================
# Models and Providers
# ===========================

# Primary LLM API — required for agent execution and reward scoring
OPENAI_API_KEY=

# Optional: override the OpenAI endpoint (e.g. to route through OpenRouter)
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Azure OpenAI (optional alternative to OpenAI)
# AZURE_API_KEY=
# AZURE_ENDPOINT=
# AZURE_API_VERSION=

# OpenRouter (optional — alternative to OPENAI_BASE_URL approach)
# OPENROUTER_API_KEY=
# OPENROUTER_API_URL=https://openrouter.ai/api/v1

# Together AI (optional)
# TOGETHER_API_KEY=

# Self-hosted vLLM (optional)
# VLLM_API_URL=
# VLLM_API_KEY=
# VLLM_MODEL=


# ===========================
# Agent Execution
# ===========================

# Web search via Serper (Google) — required for web_search action
# Tasks degrade gracefully without it (internal sources still work)
SERPER_API_KEY=


# ===========================
# Data Generation
# ===========================

# Image generation service (only needed for dataset generation)
# PEXELS_API_KEY=


# ===========================
# Docker Configuration
# ===========================

# Registry prefix for pulling images from a remote registry
# e.g. ghcr.io/servicenow → images resolved as ghcr.io/servicenow/drbench-services:DR0001
# Leave unset to use local images (default for local dev)
# DRBENCH_DOCKER_REGISTRY=ghcr.io/servicenow

# Docker image name prefix (default: drbench-services)
# DRBENCH_DOCKER_IMAGE=drbench-services

# Fallback tag when per-task baked image is not found (default: latest)
# DRBENCH_DOCKER_TAG=latest
